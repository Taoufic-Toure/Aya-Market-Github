# Configuration AyaMarket Frontend

# Supabase
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Gemini API
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Backend FastAPI
VITE_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# WebSocket FastAPI
VITE_WS_URL=ws://localhost:8000

# FedaPay backend uniquement: ne jamais exposer ces valeurs avec le prefixe VITE_
FEDAPAY_API_KEY=your_fedapay_sandbox_secret_key
FEDAPAY_ENV=sandbox
FEDAPAY_WEBHOOK_TOKEN=change_this_shared_webhook_token

# Autres cles API (si necessaire)
# VITE_CLAUDE_API_KEY=your_claude_api_key_here
# VITE_GROQ_API_KEY=your_groq_api_key_here
