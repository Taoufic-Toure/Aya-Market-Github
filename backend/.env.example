APP_NAME=AyaMarket Backend
ENVIRONMENT=development
DEBUG=true

# URL PostgreSQL Supabase (pooler recommandé pour le dev)
SUPABASE_DATABASE_URL=postgresql+asyncpg://postgres:[MOT_DE_PASSE]@[HOST]:5432/postgres

# Clés Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Clé secrète JWT
SECRET_KEY=aya_secret_key_2024

# CORS (séparé par des virgules)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Claude (Anthropic)
CLAUDE_API_KEY=ta_cle_anthropic_ici
CLAUDE_MODEL=claude-3-5-sonnet-latest

# FedaPay
FEDAPAY_API_KEY=ta_cle_fedapay_ici
FEDAPAY_ENV=sandbox

# Services IA - AyaMarket
GROQ_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
